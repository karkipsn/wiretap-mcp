{
  "name": "wiretap-mcp",
  "version": "0.1.0",
  "description": "MCP server that feeds an app's captured BLE / NFC / HTTP traffic (WireTap sessions) to AI coding agents.",
  "license": "UNLICENSED",
  "author": "Poshan Karki <psn.karki20@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/karkipsn/wiretap-mcp.git"
  },
  "type": "module",
  "bin": {
    "wiretap-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js examples/ms2-pairing-failure.wiretapsession",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
